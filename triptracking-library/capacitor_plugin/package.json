{
  "name": "capacitor-trip-tracker",
  "version": "2.0.35",
  "description": "Capacitor plugin for TripTracker — GPS trip tracking, geofencing, voice feedback. iOS + Android.",
  "main": "dist/plugin.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  },
  "unpkg": "dist/plugin.js",
  "files": [
    "dist/",
    "ios/",
    "android/",
    "src/"
  ],
  "keywords": [
    "capacitor",
    "plugin",
    "ios",
    "android",
    "triptracker",
    "gps",
    "geofence"
  ],
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch"
  },
  "peerDependencies": {
    "@capacitor/core": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@capacitor/core": "^6.0.0",
    "typescript": "~5.0.0",
    "rimraf": "^5.0.0",
    "rollup": "^4.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0"
  }
}
